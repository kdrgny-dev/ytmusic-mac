import Foundation

/// The real key lives in `LastfmSecret.swift`, which is gitignored so it never
/// reaches the public repo. Copy this file to `LastfmSecret.swift` and paste a
/// free Last.fm API key (https://www.last.fm/api/account/create). The build
/// embeds it into the binary; the "Benzerlerinden liste oluştur" feature is
/// silently disabled when the key is empty.
enum LastfmSecret {
    static let apiKey = ""
}
